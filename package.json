{
  "name": "hackathon-persona-pet",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:production": "tsc --noEmit && CLOUDFLARE_ENV=production vite build",
    "preview": "vite preview",
    "deploy": "pnpm build:production && CLOUDFLARE_ENV=production wrangler deploy",
    "check:routing": "node --experimental-strip-types src/personas.check.ts",
    "check": "pnpm check:routing && pnpm build"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.45.0",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "wrangler": "^4.111.0"
  }
}
